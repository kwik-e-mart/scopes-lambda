#!/bin/bash
# Create dedicated IAM role for Lambda execution during scope creation
# The role is named after the Lambda function and includes standard policies
# based on scope capabilities (VPC, ECR, Secrets Manager).

echo "🔍 Setting up IAM role for Lambda..."

# Auto-derive role name from Lambda function name
# The name is deterministic — AWS IAM is the source of truth (no NRN state needed)
iam_role_name="${LAMBDA_FUNCTION_NAME}-role"
iam_role_name="${iam_role_name:0:64}"

echo "   📋 role_name=$iam_role_name"

# Read capabilities from context
vpc_enabled=$(echo "$CONTEXT" | jq -r '.scope.capabilities.vpc_enabled // false')
package_type="${PACKAGE_TYPE:-$(echo "$CONTEXT" | jq -r '.scope.capabilities.package_type // "Zip"')}"

echo "   📋 vpc_enabled=$vpc_enabled | package_type=$package_type"

# Check if role already exists in AWS
existing_role=$(aws iam get-role --role-name "$iam_role_name" 2>&1 || echo "NOT_FOUND")

if ! echo "$existing_role" | grep -q "NoSuchEntity\|NOT_FOUND"; then
  echo "   ✅ Role already exists in AWS, reusing it"
  LAMBDA_ROLE_ARN=$(echo "$existing_role" | jq -r '.Role.Arn')
  LAMBDA_ROLE_NAME="$iam_role_name"
else
  # Create trust policy
  trust_policy='{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {"Service": "lambda.amazonaws.com"},
        "Action": "sts:AssumeRole"
      }
    ]
  }'

  echo ""
  echo "   📝 Creating IAM role '$iam_role_name'..."

  create_output=$(aws iam create-role \
    --role-name "$iam_role_name" \
    --assume-role-policy-document "$trust_policy" \
    --description "Lambda execution role for scope $SCOPE_ID ($SCOPE_SLUG)" \
    2>&1)
  create_exit_code=$?

  if [ $create_exit_code -ne 0 ]; then
    echo "❌ Failed to create IAM role '$iam_role_name'" >&2
    echo "💡 Possible causes:" >&2
    echo "   - Insufficient IAM permissions to create roles" >&2
    echo "   - Role name conflicts with an existing role" >&2
    echo "🔧 How to fix:" >&2
    echo "   - Verify the agent has iam:CreateRole permission" >&2
    echo "   - AWS error: $create_output" >&2
    return 1
  fi

  LAMBDA_ROLE_ARN=$(echo "$create_output" | jq -r '.Role.Arn')
  LAMBDA_ROLE_NAME="$iam_role_name"
  echo "   ✅ Role created: $LAMBDA_ROLE_ARN"

  # --- Managed policies ---

  # CloudWatch Logs (always)
  attach_output=$(aws iam attach-role-policy \
    --role-name "$iam_role_name" \
    --policy-arn "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole" \
    2>&1)
  if [ $? -ne 0 ]; then
    echo "❌ Failed to attach AWSLambdaBasicExecutionRole" >&2
    echo "   - AWS error: $attach_output" >&2
    return 1
  fi
  echo "   ✅ Attached AWSLambdaBasicExecutionRole"

  # VPC access (conditional)
  if [ "$vpc_enabled" = "true" ]; then
    attach_output=$(aws iam attach-role-policy \
      --role-name "$iam_role_name" \
      --policy-arn "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole" \
      2>&1)
    if [ $? -ne 0 ]; then
      echo "❌ Failed to attach AWSLambdaVPCAccessExecutionRole" >&2
      echo "   - AWS error: $attach_output" >&2
      return 1
    fi
    echo "   ✅ Attached AWSLambdaVPCAccessExecutionRole"
  fi

  # --- Inline policies ---

  # Secrets Manager read — scoped to this scope's secrets (wildcard covers all deployments)
  sm_policy=$(jq -cn \
    --arg scope_id "$SCOPE_ID" \
    '{
      Version: "2012-10-17",
      Statement: [{
        Effect: "Allow",
        Action: ["secretsmanager:GetSecretValue"],
        Resource: ("arn:aws:secretsmanager:*:*:secret:nullplatform/" + $scope_id + "/*")
      }]
    }')

  put_output=$(aws iam put-role-policy \
    --role-name "$iam_role_name" \
    --policy-name "secrets-manager-parameters-read" \
    --policy-document "$sm_policy" \
    2>&1)
  if [ $? -ne 0 ]; then
    echo "❌ Failed to put secrets-manager-parameters-read policy" >&2
    echo "   - AWS error: $put_output" >&2
    return 1
  fi
  echo "   ✅ Added inline policy: secrets-manager-parameters-read"

  # ECR pull — required for container image Lambda (conditional)
  if [ "$package_type" = "Image" ]; then
    ecr_policy='{
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": ["ecr:BatchGetImage", "ecr:GetDownloadUrlForLayer"],
          "Resource": "*"
        },
        {
          "Effect": "Allow",
          "Action": ["ecr:GetAuthorizationToken"],
          "Resource": "*"
        }
      ]
    }'

    put_output=$(aws iam put-role-policy \
      --role-name "$iam_role_name" \
      --policy-name "ecr-image-pull" \
      --policy-document "$ecr_policy" \
      2>&1)
    if [ $? -ne 0 ]; then
      echo "❌ Failed to put ecr-image-pull policy" >&2
      echo "   - AWS error: $put_output" >&2
      return 1
    fi
    echo "   ✅ Added inline policy: ecr-image-pull"
  fi

  # SQS consume — required for SQS trigger (conditional)
  sqs_queue_arns=$(echo "$CONTEXT" | jq '.scope.capabilities.triggers.sqs.queue_arns // []')
  sqs_queue_count=$(echo "$sqs_queue_arns" | jq 'length')

  if [ "$sqs_queue_count" -gt 0 ]; then
    sqs_policy=$(echo "$sqs_queue_arns" | jq -c \
      '{
        Version: "2012-10-17",
        Statement: [{
          Effect: "Allow",
          Action: [
            "sqs:ReceiveMessage",
            "sqs:DeleteMessage",
            "sqs:GetQueueAttributes"
          ],
          Resource: .
        }]
      }')

    put_output=$(aws iam put-role-policy \
      --role-name "$iam_role_name" \
      --policy-name "sqs-consume" \
      --policy-document "$sqs_policy" \
      2>&1)
    if [ $? -ne 0 ]; then
      echo "❌ Failed to put sqs-consume policy" >&2
      echo "   - AWS error: $put_output" >&2
      return 1
    fi
    echo "   ✅ Added inline policy: sqs-consume ($sqs_queue_count queue(s))"
  fi
fi

export LAMBDA_ROLE_ARN
export LAMBDA_ROLE_NAME

echo ""
echo "✨ IAM role ready: role_arn=$LAMBDA_ROLE_ARN"
