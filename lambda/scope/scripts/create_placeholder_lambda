#!/bin/bash
# Create the placeholder Lambda function using a pre-built public container image.
# The image is published once via lambda/scope/placeholder/publish and configured
# via PLACEHOLDER_IMAGE_URI in values.yaml.

source "$SERVICE_PATH/utils/log"

log info "рҹ”Қ Creating placeholder Lambda function (container image)..."

if [ -z "${LAMBDA_FUNCTION_NAME:-}" ]; then
  echo "вқҢ LAMBDA_FUNCTION_NAME is not set" >&2
  echo "рҹ’Ў Possible causes:" >&2
  echo "   - build_context did not compute the function name" >&2
  echo "рҹ”§ How to fix:" >&2
  echo "   - Ensure build_context runs before this script" >&2
  return 1
fi

if [ -z "${LAMBDA_ROLE_ARN:-}" ]; then
  echo "вқҢ LAMBDA_ROLE_ARN is not set" >&2
  echo "рҹ’Ў Possible causes:" >&2
  echo "   - create_iam_role did not run or failed" >&2
  echo "рҹ”§ How to fix:" >&2
  echo "   - Ensure create_iam_role runs before this script" >&2
  return 1
fi

if [ -z "${OUTPUT_DIR:-}" ]; then
  echo "вқҢ OUTPUT_DIR is not set" >&2
  echo "рҹ’Ў Possible causes:" >&2
  echo "   - The scope runner did not set a working directory" >&2
  return 1
fi

placeholder_image_base="${PLACEHOLDER_IMAGE_URI:-public.ecr.aws/nullplatform/aws-lambda/nullplatform-lambda-placeholder:latest}"
architecture="${ARCHITECTURE:-arm64}"

# Lambda does not support multi-arch manifest lists (OCI image index).
# Images are published per-architecture with a -{arch} suffix on the tag.
# e.g. :latest вҶ’ :latest-arm64 or :latest-amd64
if [[ "$placeholder_image_base" == *":"* ]]; then
  placeholder_image_uri="${placeholder_image_base}-${architecture}"
else
  placeholder_image_uri="${placeholder_image_base}:latest-${architecture}"
fi

log debug "   рҹ“Ӣ function_name=$LAMBDA_FUNCTION_NAME"
log debug "   рҹ“Ӣ role_arn=$LAMBDA_ROLE_ARN"
log debug "   рҹ“Ӣ architecture=$architecture"
log debug "   рҹ“Ӣ placeholder_image_uri=$placeholder_image_uri"

# Check if function already exists
echo ""
log info "   рҹ“Ў Checking if function already exists..."

existing_function=$(aws lambda get-function \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  2>&1 || echo "NOT_FOUND")

if ! echo "$existing_function" | grep -q "ResourceNotFoundException\|NOT_FOUND"; then
  log info "   вң… Function already exists - skipping creation"

  LAMBDA_FUNCTION_ARN=$(echo "$existing_function" | jq -r '.Configuration.FunctionArn')
  export LAMBDA_FUNCTION_ARN

  log debug "   рҹ“Ӣ function_arn=$LAMBDA_FUNCTION_ARN"
  return 0
fi

# Validate placeholder image exists
echo ""
log info "   рҹ“Ў Validating placeholder image..."

image_found=false

if [[ "$placeholder_image_uri" == public.ecr.aws/* ]]; then
  # Public ECR: validate via OCI token + manifest API (no AWS credentials needed)
  image_ref="${placeholder_image_uri#public.ecr.aws/}"
  image_tag="${image_ref##*:}"
  image_path="${image_ref%:*}"
  [[ "$image_ref" != *":"* ]] && { image_tag="latest"; image_path="$image_ref"; }

  token_response=$(curl -sfL \
    "https://public.ecr.aws/token/?scope=repository:${image_path}:pull&service=public.ecr.aws" \
    2>/dev/null || echo "")

  token=""
  [ -n "$token_response" ] && token=$(echo "$token_response" | jq -r '.token // empty' 2>/dev/null || echo "")

  if [ -z "$token" ]; then
    echo "" >&2
    echo "вқҢ Cannot reach public ECR to validate placeholder image" >&2
    echo "" >&2
    echo "рҹ’Ў Possible causes:" >&2
    echo "   вҖў The agent has no outbound internet access" >&2
    echo "   вҖў public.ecr.aws is temporarily unavailable" >&2
    echo "" >&2
    echo "рҹ”§ How to fix:" >&2
    echo "   вҖў Verify outbound connectivity: curl -s https://public.ecr.aws" >&2
    return 1
  fi

  http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.docker.distribution.manifest.v2+json" \
    "https://public.ecr.aws/v2/${image_path}/manifests/${image_tag}")

  [ "$http_code" = "200" ] && image_found=true
else
  # Private ECR: validate via aws ecr describe-images (uses existing AWS credentials)
  ecr_registry="${placeholder_image_uri%%/*}"
  ecr_region=$(echo "$ecr_registry" | cut -d. -f4)
  ecr_rest="${placeholder_image_uri#*/}"
  ecr_repo="${ecr_rest%:*}"
  ecr_tag="${ecr_rest##*:}"
  [[ "$ecr_rest" != *":"* ]] && ecr_tag="latest"

  if aws ecr describe-images \
      --repository-name "$ecr_repo" \
      --image-ids "imageTag=$ecr_tag" \
      --region "$ecr_region" &>/dev/null 2>&1; then
    image_found=true
  fi
fi

if [ "$image_found" = "false" ]; then
  echo "" >&2
  echo "вқҢ Placeholder image not found: $placeholder_image_uri" >&2
  echo "" >&2
  echo "рҹ’Ў Possible causes:" >&2
  echo "   вҖў The image has not been published yet" >&2
  echo "   вҖў PLACEHOLDER_IMAGE_URI in values.yaml points to a wrong tag or path" >&2
  echo "" >&2
  echo "рҹ”§ How to fix:" >&2
  echo "   вҖў Publish the image once by running: lambda/scope/placeholder/publish" >&2
  echo "   вҖў Verify PLACEHOLDER_IMAGE_URI=$placeholder_image_uri is correct" >&2
  return 1
fi

log debug "   вң… Placeholder image found"

# Build tags argument for AWS CLI
tags_arg=""
if [ -n "${RESOURCE_TAGS_JSON:-}" ]; then
  tags_arg=$(echo "$RESOURCE_TAGS_JSON" | jq -r 'to_entries | map("\(.key)=\(.value)") | join(",")')
fi

# Create the Lambda function with the pre-built placeholder image
echo ""
log info "   рҹ“Ў Creating Lambda function..."

create_output=$(aws lambda create-function \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  --package-type Image \
  --code "ImageUri=$placeholder_image_uri" \
  --architectures "$architecture" \
  --role "$LAMBDA_ROLE_ARN" \
  --memory-size 128 \
  --timeout 30 \
  --description "Placeholder Lambda - created by nullplatform" \
  ${tags_arg:+--tags "$tags_arg"} \
  2>&1)
create_exit_code=$?

# Retry on IAM role propagation delay
if [ $create_exit_code -ne 0 ] && \
   echo "$create_output" | grep -q "The role defined for the function cannot be assumed"; then
  log warn "   вҡ пёҸ  Waiting for IAM role propagation..."

  max_retries=5
  retry_delay=10

  for i in $(seq 1 $max_retries); do
    log info "   рҹ“қ Retry $i/$max_retries (waiting ${retry_delay}s)..."
    sleep "$retry_delay"

    create_output=$(aws lambda create-function \
      --function-name "$LAMBDA_FUNCTION_NAME" \
      --package-type Image \
      --code "ImageUri=$placeholder_image_uri" \
      --architectures "$architecture" \
      --role "$LAMBDA_ROLE_ARN" \
      --memory-size 128 \
      --timeout 30 \
      --description "Placeholder Lambda - created by nullplatform" \
      ${tags_arg:+--tags "$tags_arg"} \
      2>&1)
    create_exit_code=$?

    [ $create_exit_code -eq 0 ] && break
    retry_delay=$((retry_delay + 10))
  done
fi

if ! echo "$create_output" | grep -q "FunctionArn"; then
  echo "" >&2
  echo "вқҢ Failed to create Lambda function '$LAMBDA_FUNCTION_NAME'" >&2
  echo "" >&2

  if echo "$create_output" | grep -qi "ImageNotFoundException\|invalid.*image\|repository does not exist"; then
    echo "  рҹ–јпёҸ  Error: Placeholder image not found or not accessible" >&2
    echo "" >&2
    echo "  рҹ’Ў Possible causes:" >&2
    echo "    вҖў The placeholder image has not been published yet" >&2
    echo "    вҖў PLACEHOLDER_IMAGE_URI=$placeholder_image_uri is incorrect" >&2
    echo "" >&2
    echo "  рҹ”§ How to fix:" >&2
    echo "    вҖў Publish the image once by running: lambda/scope/placeholder/publish" >&2
  else
    echo "  рҹ’Ў Possible causes:" >&2
    echo "    вҖў IAM role not yet propagated (even after retries)" >&2
    echo "    вҖў Insufficient permissions to create Lambda functions" >&2
    echo "    вҖў Invalid architecture '$architecture'" >&2
    echo "" >&2
    echo "  рҹ”§ How to fix:" >&2
    echo "    вҖў Verify the agent has lambda:CreateFunction permission" >&2
    echo "    вҖў Check that role_arn=$LAMBDA_ROLE_ARN exists and is assumable by Lambda" >&2
    echo "    вҖў AWS error: $create_output" >&2
  fi

  echo "" >&2
  return 1
fi

LAMBDA_FUNCTION_ARN=$(echo "$create_output" | jq -r '.FunctionArn')
log debug "   вң… Function created: function_arn=$LAMBDA_FUNCTION_ARN"

# Create main alias pointing to $LATEST
echo ""
log info "   рҹ“қ Creating main alias..."

alias_name="${LAMBDA_MAIN_ALIAS_NAME:-main}"

aws lambda create-alias \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  --name "$alias_name" \
  --function-version "\$LATEST" \
  --description "Main alias for traffic routing" \
  >/dev/null 2>&1 || true

log debug "   вң… Alias '$alias_name' created"

export LAMBDA_FUNCTION_ARN

echo ""
log info "вңЁ Placeholder Lambda created: function_name=$LAMBDA_FUNCTION_NAME, function_arn=$LAMBDA_FUNCTION_ARN"
