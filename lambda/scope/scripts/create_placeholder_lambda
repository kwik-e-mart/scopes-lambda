#!/bin/bash
# Build a placeholder Lambda container image and create the Lambda function.
# The placeholder uses a minimal Node.js handler (lambda/scope/placeholder/) pushed
# to a dedicated ECR repository (nullplatform-lambda-placeholder) so that the
# function is always created with Image package type from the start, avoiding
# any Zip → Image migration at first deployment.

source "$SERVICE_PATH/utils/log"

log info "🔍 Creating placeholder Lambda function (container image)..."

if [ -z "${LAMBDA_FUNCTION_NAME:-}" ]; then
  echo "❌ LAMBDA_FUNCTION_NAME is not set" >&2
  echo "💡 Possible causes:" >&2
  echo "   - build_context did not compute the function name" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Ensure build_context runs before this script" >&2
  return 1
fi

if [ -z "${LAMBDA_ROLE_ARN:-}" ]; then
  echo "❌ LAMBDA_ROLE_ARN is not set" >&2
  echo "💡 Possible causes:" >&2
  echo "   - create_iam_role did not run or failed" >&2
  echo "🔧 How to fix:" >&2
  echo "   - Ensure create_iam_role runs before this script" >&2
  return 1
fi

if [ -z "${OUTPUT_DIR:-}" ]; then
  echo "❌ OUTPUT_DIR is not set" >&2
  echo "💡 Possible causes:" >&2
  echo "   - The scope runner did not set a working directory" >&2
  return 1
fi

architecture="${ARCHITECTURE:-arm64}"

log debug "   📋 function_name=$LAMBDA_FUNCTION_NAME"
log debug "   📋 role_arn=$LAMBDA_ROLE_ARN"
log debug "   📋 architecture=$architecture"

# Check if function already exists
echo ""
log info "   📡 Checking if function already exists..."

existing_function=$(aws lambda get-function \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  2>&1 || echo "NOT_FOUND")

if ! echo "$existing_function" | grep -q "ResourceNotFoundException\|NOT_FOUND"; then
  log info "   ✅ Function already exists - skipping creation"

  LAMBDA_FUNCTION_ARN=$(echo "$existing_function" | jq -r '.Configuration.FunctionArn')
  export LAMBDA_FUNCTION_ARN

  log debug "   📋 function_arn=$LAMBDA_FUNCTION_ARN"
  return 0
fi

# Resolve AWS account and region from context
AWS_REGION=$(echo "$CONTEXT" | jq -r '.providers["cloud-providers"].credentials.region // "us-east-1"')
AWS_ACCOUNT_ID=$(echo "$CONTEXT" | jq -r '.providers["cloud-providers"].credentials.account_id // ""')

if [ -z "$AWS_ACCOUNT_ID" ] || [ "$AWS_ACCOUNT_ID" = "null" ]; then
  AWS_ACCOUNT_ID=$(aws sts get-caller-identity --query 'Account' --output text 2>/dev/null || echo "")
fi

if [ -z "$AWS_ACCOUNT_ID" ]; then
  echo "" >&2
  echo "❌ Unable to determine AWS account ID" >&2
  echo "" >&2
  echo "💡 Possible causes:" >&2
  echo "   • account_id is missing from the cloud-provider context" >&2
  echo "   • AWS credentials do not allow sts:GetCallerIdentity" >&2
  return 1
fi

# Placeholder ECR image coordinates
# One shared repo per AWS account/region; one tag per architecture so both
# arm64 and x86_64 scopes can coexist without rebuilding each other's image.
ecr_registry="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
placeholder_repo="nullplatform-lambda-placeholder"
placeholder_tag="stable-${architecture}"
placeholder_image_uri="${ecr_registry}/${placeholder_repo}:${placeholder_tag}"

log debug "   📋 placeholder_image_uri=$placeholder_image_uri"

# Check docker is available
if ! command -v docker &>/dev/null; then
  echo "" >&2
  echo "❌ docker is required to build the placeholder container image" >&2
  echo "" >&2
  echo "💡 Possible causes:" >&2
  echo "   • The agent container does not include the Docker CLI" >&2
  echo "🔧 How to fix:" >&2
  echo "   • Ensure the agent image has docker installed and the Docker socket is mounted" >&2
  return 1
fi

# Create ECR repository if it does not exist
echo ""
log info "   📡 Ensuring ECR repository: $placeholder_repo"

if ! aws ecr describe-repositories \
    --repository-names "$placeholder_repo" \
    --region "$AWS_REGION" &>/dev/null 2>&1; then
  log info "   📝 Creating ECR repository..."
  aws ecr create-repository \
    --repository-name "$placeholder_repo" \
    --image-scanning-configuration scanOnPush=false \
    --region "$AWS_REGION" >/dev/null
  log debug "   ✅ ECR repository created"
else
  log debug "   ✅ ECR repository already exists"
fi

# Build and push only if the architecture-specific tag does not exist yet
image_exists=false
if aws ecr describe-images \
    --repository-name "$placeholder_repo" \
    --image-ids imageTag="$placeholder_tag" \
    --region "$AWS_REGION" &>/dev/null 2>&1; then
  image_exists=true
  log debug "   ✅ Placeholder image already present in ECR - skipping build"
fi

if [ "$image_exists" = "false" ]; then
  log info "   📝 Authenticating docker to ECR..."
  aws ecr get-login-password --region "$AWS_REGION" | \
    docker login --username AWS --password-stdin "$ecr_registry" >/dev/null

  # Map Lambda architecture to Docker platform
  docker_platform="linux/amd64"
  if [ "$architecture" = "arm64" ]; then
    docker_platform="linux/arm64"
  fi

  echo ""
  log info "   📝 Building placeholder image (platform=$docker_platform)..."
  docker build \
    --platform "$docker_platform" \
    --tag "$placeholder_image_uri" \
    "$SERVICE_PATH/scope/placeholder/"
  log debug "   ✅ Image built"

  log info "   📝 Pushing placeholder image to ECR..."
  docker push "$placeholder_image_uri" >/dev/null
  log debug "   ✅ Image pushed: $placeholder_image_uri"
fi

# Build tags argument for AWS CLI
tags_arg=""
if [ -n "${RESOURCE_TAGS_JSON:-}" ]; then
  tags_arg=$(echo "$RESOURCE_TAGS_JSON" | jq -r 'to_entries | map("\(.key)=\(.value)") | join(",")')
fi

# Create the Lambda function with Image package type
echo ""
log info "   📡 Creating Lambda function..."

create_output=$(aws lambda create-function \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  --package-type Image \
  --code "ImageUri=$placeholder_image_uri" \
  --architectures "$architecture" \
  --role "$LAMBDA_ROLE_ARN" \
  --memory-size 128 \
  --timeout 30 \
  --description "Placeholder Lambda - created by nullplatform" \
  ${tags_arg:+--tags "$tags_arg"} \
  2>&1)
create_exit_code=$?

# Retry on IAM role propagation delay
if [ $create_exit_code -ne 0 ] && \
   echo "$create_output" | grep -q "The role defined for the function cannot be assumed"; then
  log warn "   ⚠️  Waiting for IAM role propagation..."

  max_retries=5
  retry_delay=10

  for i in $(seq 1 $max_retries); do
    log info "   📝 Retry $i/$max_retries (waiting ${retry_delay}s)..."
    sleep "$retry_delay"

    create_output=$(aws lambda create-function \
      --function-name "$LAMBDA_FUNCTION_NAME" \
      --package-type Image \
      --code "ImageUri=$placeholder_image_uri" \
      --architectures "$architecture" \
      --role "$LAMBDA_ROLE_ARN" \
      --memory-size 128 \
      --timeout 30 \
      --description "Placeholder Lambda - created by nullplatform" \
      ${tags_arg:+--tags "$tags_arg"} \
      2>&1)
    create_exit_code=$?

    [ $create_exit_code -eq 0 ] && break
    retry_delay=$((retry_delay + 10))
  done
fi

if ! echo "$create_output" | grep -q "FunctionArn"; then
  echo "" >&2
  echo "❌ Failed to create Lambda function '$LAMBDA_FUNCTION_NAME'" >&2
  echo "" >&2
  echo "💡 Possible causes:" >&2
  echo "   • IAM role not yet propagated (even after retries)" >&2
  echo "   • Insufficient permissions to create Lambda functions" >&2
  echo "   • Invalid architecture '$architecture'" >&2
  echo "   • Resource limits exceeded in this AWS region" >&2
  echo "" >&2
  echo "🔧 How to fix:" >&2
  echo "   • Verify the agent has lambda:CreateFunction permission" >&2
  echo "   • Check that role_arn=$LAMBDA_ROLE_ARN exists and is assumable by Lambda" >&2
  echo "   • AWS error: $create_output" >&2
  return 1
fi

LAMBDA_FUNCTION_ARN=$(echo "$create_output" | jq -r '.FunctionArn')
log debug "   ✅ Function created: function_arn=$LAMBDA_FUNCTION_ARN"

# Create main alias pointing to $LATEST
echo ""
log info "   📝 Creating main alias..."

alias_name="${LAMBDA_MAIN_ALIAS_NAME:-main}"

aws lambda create-alias \
  --function-name "$LAMBDA_FUNCTION_NAME" \
  --name "$alias_name" \
  --function-version "\$LATEST" \
  --description "Main alias for traffic routing" \
  >/dev/null 2>&1 || true

log debug "   ✅ Alias '$alias_name' created"

export LAMBDA_FUNCTION_ARN

echo ""
log info "✨ Placeholder Lambda created: function_name=$LAMBDA_FUNCTION_NAME, function_arn=$LAMBDA_FUNCTION_ARN"
