#!/bin/bash

source "$SERVICE_PATH/utils/log"

log info "🔍 Configuring IAM role for deployment..."

# If LAMBDA_ROLE_ARN is already set (e.g. exported by create_iam_role during scope create),
# use it directly. Otherwise derive role name from LAMBDA_FUNCTION_NAME and look up in AWS.
role_arn="${LAMBDA_ROLE_ARN:-}"

if [ -z "$role_arn" ] || [ "$role_arn" = "null" ]; then
  role_name="${LAMBDA_FUNCTION_NAME}-role"
  role_name="${role_name:0:64}"
  log debug "   ✅ role_name=$role_name (lookup)"

  role_output=$(aws iam get-role --role-name "$role_name" 2>&1)
  role_exit=$?

  if [ $role_exit -ne 0 ]; then
    echo ""
    echo "   ❌ IAM role '$role_name' not found" >&2
    echo "" >&2
    echo "  💡 Possible causes:" >&2
    echo "    • Scope was not created via the standard create workflow" >&2
    echo "    • create_iam_role script failed during scope creation" >&2
    echo "" >&2
    echo "  🔧 How to fix:" >&2
    echo "    • Re-run the scope create workflow to provision the IAM role" >&2
    echo "    • AWS error: $role_output" >&2
    echo "" >&2
    return 1
  fi

  role_arn=$(echo "$role_output" | jq -r '.Role.Arn')
fi

log debug "   ✅ role_arn=$role_arn"

TOFU_VARIABLES=$(echo "$TOFU_VARIABLES" | jq \
  --arg role_arn "$role_arn" \
  '. + {lambda_role_arn: $role_arn, iam_create_role: false}')

echo ""
log info "✨ IAM configured (role_arn=$role_arn)"
echo ""

# Add module to composition list (needed for cross-module lambda_role_arn local)
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
module_name="${script_dir}/modules"

if [[ -n $MODULES_TO_USE ]]; then
  MODULES_TO_USE="$MODULES_TO_USE,$module_name"
else
  MODULES_TO_USE="$module_name"
fi
